{
    "buildCommand": "vite build",
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "framework": null,
    "functions": {
        "api/*.py": {
            "maxDuration": 10
        },
        "api/*.ts": {
            "maxDuration": 10
        }
    },
    "rewrites": [
        {
            "source": "/api/transcribe-youtube",
            "destination": "/api/transcribe-youtube.py"
        },
        {
            "source": "/api/convert-yt-mp3",
            "destination": "/api/convert-yt-mp3.py"
        },
        {
            "source": "/api/transcribe",
            "destination": "/api/transcribe.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/sw.js",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                },
                {
                    "key": "Service-Worker-Allowed",
                    "value": "/"
                }
            ]
        },
        {
            "source": "/manifest.webmanifest",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/manifest+json"
                }
            ]
        }
    ]
}